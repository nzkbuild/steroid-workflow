{
  "name": "steroid-workflow",
  "version": "7.0.0-beta.2",
  "description": "AI agency-in-a-box for non-technical vibe coders. 8-skill pipeline with two-stage review, handoff reports, analytics dashboard, structured memory, smart recovery, prioritized stories, codebase scanning, spec-driven development, tech research, TDD, circuit breakers, verification, intent routing, and anti-summarization guards.",
  "bin": {
    "steroid-workflow": "bin/cli.js"
  },
  "main": "bin/cli.js",
  "files": [
    "bin/",
    "skills/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check:consistency": "node scripts/check-consistency.js",
    "test": "node test/smoke.test.cjs && node test/unit/run-all.cjs",
    "test:smoke": "node test/smoke.test.cjs",
    "test:unit": "node test/unit/run-all.cjs",
    "lint": "eslint --max-warnings=0 \"bin/**/*.{js,cjs}\" \"src/utils/**/*.cjs\" \"test/**/*.cjs\" \"scripts/**/*.js\"",
    "format": "prettier --write \"bin/**/*.{js,cjs}\" \"src/utils/**/*.cjs\" \"test/**/*.cjs\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"bin/**/*.{js,cjs}\" \"src/utils/**/*.cjs\" \"test/**/*.cjs\" \"scripts/**/*.js\"",
    "prepublishOnly": "node scripts/sync-version.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nzkbuild/steroid-workflow.git"
  },
  "keywords": [
    "ai",
    "agentic",
    "workflow",
    "vibe-coding",
    "tdd",
    "circuit-breaker",
    "spec-driven",
    "autonomous",
    "research",
    "claude",
    "cursor",
    "gemini",
    "antigravity",
    "skills"
  ],
  "author": "nzkbuild",
  "license": "MIT",
  "homepage": "https://github.com/nzkbuild/steroid-workflow#readme",
  "bugs": {
    "url": "https://github.com/nzkbuild/steroid-workflow/issues"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "@accesslint/core": "^0.8.8",
    "happy-dom": "^20.8.4"
  }
}
